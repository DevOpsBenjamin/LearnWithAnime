{
  "name": "learnwithanime-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:front": "pnpm --filter learnwithanime-frontend build",
    "build:back": "cd backend && cargo build --release",
    "build": "pnpm build:front && pnpm build:back",
    "dev": "cd backend && cargo run",
    "start": "cd backend && cargo run --release"
  }
}
